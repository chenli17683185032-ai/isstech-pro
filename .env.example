ISSTECH_BASE_URL=http://ipsapro.isstech.com
ISSTECH_PASSPORT_URL=https://passport.isstech.com
ISSTECH_TIMEOUT_SECONDS=20
ISSTECH_MAX_ATTACHMENT_BYTES=26214400
ISSTECH_MAX_MATERIAL_BYTES=104857600
ISSTECH_SESSION_TTL_SECONDS=3600
ISSTECH_DATA_DIR=data
# Optional override; default is <ISSTECH_DATA_DIR>/workflow-center.sqlite3
# ISSTECH_DATABASE_PATH=/absolute/path/to/workflow-center.sqlite3
# Supply credentials only at runtime. Never commit real values.
ISSTECH_USERNAME=
ISSTECH_PASSWORD=
# Optional chat-capable follow-up assistant. Prefer tools/configure_assistant_keychain.py
# for the daily LaunchAgent. Image endpoints and gpt-image-2 are rejected here.
# ISSTECH_ASSISTANT_ENDPOINT=https://provider.example/v1/chat/completions
# ISSTECH_ASSISTANT_MODEL=chat-model
# ISSTECH_ASSISTANT_API_KEY=
