.DS_Store
.env
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# Raw browser/network evidence may contain credentials, cookies, tickets, or
# business data. Only reviewed, redacted fixtures belong in version control.
captures/raw/**
captures/playwright/**
captures/*.har
captures/login_fail_*.html
!captures/raw/.gitkeep
!captures/redacted/**

# Local workflow state and business-data exports are runtime-only.
data/

# Generated design concepts and visual QA references are local-only.
outputs/
web/node_modules/
